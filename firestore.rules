rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------
    // 🛠️ دوال مساعدة (لترتيب الكود ومنع التكرار)
    // ---------------------------------------------------------
    
    // 1. هل المستخدم مسجل دخول؟
    function isSignedIn() {
      return request.auth != null;
    }

    // 2. هل المستخدم هو صاحب الملف الحالي؟ (للتعديل والقراءة والحذف)
    function isOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 3. هل الملف الجديد يحمل توقيع المستخدم الصحيح؟ (للإنشاء فقط)
    function isValidNewDoc() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // 4. هل الملف مسموح بنشره للعامة؟
    function isPublic() {
      return resource.data.isPublic == true;
    }

    // ---------------------------------------------------------
    // 🔒 قواعد الحماية (Application Rules)
    // ---------------------------------------------------------

    // القفل العام: نمنع أي وصول غير محدد
    match /{document=**} {
      allow read, write: if false;
    }

    // بيانات الحساب الخاصة (مخفية للجميع إلا لصاحب الحساب)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // إحصائيات دراسة المستخدم (تُقرأ للجميع كلوحة أبطال، وتُعدل من صاحبها فقط)
    match /user_stats/{userId} {
      allow read: if isSignedIn(); // ✅ الكل يقدر يقراها حتى يشتغل Leaderboard
      allow write: if isSignedIn() && request.auth.uid == userId; // 🔒 التغيير فقط لك
    }

    // ---------------------------------------------------------
    // 📝 المجموعات الأساسية (مع دعم المشاركة العامة)
    // ---------------------------------------------------------

    // الملاحظات: يقرأها المالك أو أي شخص إذا كانت عامة
    match /notes/{noteId} {
      allow read: if isOwner() || isPublic();
      allow create: if isValidNewDoc();  // ✅ تضمن أنك تنشئ ملاحظة لنفسك فقط
      allow update, delete: if isOwner(); // ✅ المالك فقط يعدل ويحذف
    }

    // الجداول الدراسية: يقرأها المالك أو أي شخص إذا كانت عامة
    match /classes/{classId} {
      allow read: if isOwner() || isPublic();
      allow create: if isValidNewDoc();
      allow update, delete: if isOwner();
    }

    // ---------------------------------------------------------
    // 🔒 المجموعات الخاصة (لا توجد مشاركة عامة)
    // ---------------------------------------------------------

    match /tasks/{taskId} {
      allow read, update, delete: if isOwner();
      allow create: if isValidNewDoc();
    }

    match /quizzes/{quizId} {
      allow read, update, delete: if isOwner();
      allow create: if isValidNewDoc();
    }

    match /assignments/{assignmentId} {
      allow read, update, delete: if isOwner();
      allow create: if isValidNewDoc();
    }

    // ---------------------------------------------------------
    // ⚠️ مجموعات Legacy (إذا لم تعد تستخدمها، يفضل حذفها مستقبلاً)
    // ---------------------------------------------------------
    match /public/notes/{noteId} {
      allow read: if true;
      allow write: if isOwner(); 
    }
    match /public/schedules/{scheduleId} {
      allow read: if true;
      allow write: if isOwner();
    }
  }
}