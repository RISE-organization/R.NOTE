rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------
    // 🛠️ دوال مساعدة (لترتيب الكود ومنع التكرار)
    // ---------------------------------------------------------
    
    // 1. هل المستخدم مسجل دخول؟
    function isSignedIn() {
      return request.auth != null;
    }

    // 2. هل المستخدم هو صاحب الملف الحالي؟ (للتعديل والقراءة والحذف)
    function isOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 3. هل الملف الجديد يحمل توقيع المستخدم الصحيح؟ (للإنشاء فقط)
    function isValidNewDoc() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // 4. هل الملف مسموح بنشره للعامة؟
    function isPublic() {
      return resource.data.isPublic == true;
    }

    // ---------------------------------------------------------
    // 🔒 قواعد الحماية (Application Rules)
    // ---------------------------------------------------------

    // القفل العام: نمنع أي وصول غير محدد
    match /{document=**} {
      allow read, write: if false;
    }

    // بيانات الحساب الخاصة (مخفية للجميع إلا لصاحب الحساب)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // إحصائيات دراسة المستخدم
    match /user_stats/{userId} {
      allow read: if isSignedIn(); // ✅ الكل يقدر يقراها حتى يشتغل Leaderboard والبحث عن المستخدمين
      allow write: if isSignedIn() && request.auth.uid == userId; // 🔒 التغيير فقط لك
      
      // ✅ المجموعات الفرعية للإحصائيات اليومية والأوسمة
      match /pomodoro_daily/{date} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /achievements/{id} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // ---------------------------------------------------------
    // 📝 المجموعات الأساسية (مع دعم المشاركة العامة)
    // ---------------------------------------------------------

    match /notes/{noteId} {
      allow read: if isOwner() || isPublic();
      allow create: if isValidNewDoc();
      allow update, delete: if isOwner();
    }

    match /classes/{classId} {
      allow read: if isOwner() || isPublic();
      allow create: if isValidNewDoc();
      allow update, delete: if isOwner();
    }

    // ---------------------------------------------------------
    // 🔒 المجموعات الخاصة (لا توجد مشاركة عامة)
    // ---------------------------------------------------------

    match /tasks/{taskId} {
      allow read, update, delete: if isOwner();
      allow create: if isValidNewDoc();
    }

    match /quizzes/{quizId} {
      allow read, update, delete: if isOwner();
      allow create: if isValidNewDoc();
    }

    match /assignments/{assignmentId} {
      allow read, update, delete: if isOwner();
      allow create: if isValidNewDoc();
    }

    // ---------------------------------------------------------
    // 🤝 نظام غرف الدراسة والدعوات (جديد)
    // ---------------------------------------------------------

    // غرف الدراسة الجماعية
    match /active_rooms/{roomId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && (
        request.auth.uid in request.resource.data.participants || 
        request.auth.uid == request.resource.data.hostId
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.hostId;
    }

    // نظام الدعوات
    match /study_invites/{inviteId} {
      allow create: if isSignedIn();
      // السماح للمرسل أو المستقبل (عبر المعرف أو البريد) بالتعامل مع الدعوة
      allow read, update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.receiverId ||
        request.auth.token.email == resource.data.receiverEmail
      );
    }

    // ---------------------------------------------------------
    // ⚠️ مجموعات Legacy
    // ---------------------------------------------------------
    match /public/notes/{noteId} {
      allow read: if true;
      allow write: if isOwner(); 
    }
    match /public/schedules/{scheduleId} {
      allow read: if true;
      allow write: if isOwner();
    }

    match /ai_answers_cache/{document} {
      allow read, write: if true; 
    }
  }
}